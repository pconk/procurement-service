syntax = "proto3";

option java_multiple_files = true;
option java_package = "com.pconk.procurement.grpc";

service ProcurementService {
  rpc CreateOrder (ProcurementRequest) returns (ProcurementResponse);
}

message ProcurementRequest {
  string item_id = 1;
  int32 quantity = 2;
}

message ProcurementResponse {
  string order_id = 1;
  string status = 2;
}