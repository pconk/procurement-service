package com.pconk.procurement.api.grpc;

import jakarta.enterprise.context.ApplicationScoped;

import java.util.UUID;

import com.pconk.procurement.domain.model.Procurement;

@ApplicationScoped
public class ProcurementService {
    
    public Procurement CreateOrder(String itemId, int qty) {
        // Logika bisnis: validasi stok, hitung harga, dll.
        // Panggil repository untuk simpan ke DB
        return new Procurement(UUID.randomUUID().toString(), itemId, qty);
    }
}